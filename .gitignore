# ══════════════════════════════════════════════════════════════
# MUÑEGON POS — .gitignore
# ══════════════════════════════════════════════════════════════

# ── Entornos (NUNCA al repositorio) ───────────────────────────
.env
.env.development
.env.production
.env.local
*.env

# ── Bases de datos locales ─────────────────────────────────────
prisma/dev.db
prisma/dev.db-journal
prod.db
*.db-shm
*.db-wal

# ── Build outputs ──────────────────────────────────────────────
dist/
src-tauri/target/
.astro/

# ── Node ──────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Prisma ────────────────────────────────────────────────────
prisma/generated/

# ── OS / Editor ───────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
