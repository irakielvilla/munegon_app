---
// ══════════════════════════════════════════════════════════════
// MUÑEGON POS — Layout Base
// Incluye: fuentes, CSS global, e inicialización del sync listener
// ══════════════════════════════════════════════════════════════

export interface Props {
  title?: string;
}

import '../styles/global.css';

const { title = 'Muñegon POS' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Muñegon POS — Sistema de Punto de Venta e Inventario Offline-First" />
    <meta name="robots" content="noindex" /><!-- App de escritorio, no indexar -->

    <title>{title} | Muñegon POS</title>

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- El CSS global se importa en el frontmatter para que Vite lo procese -->
  </head>

  <body>
    <slot />

    <!-- Inicializar el listener de sincronización al cargar la app -->
    <script>
      import { iniciarSyncListener } from '../lib/sync-listener';

      // Intentar iniciar el listener de sincronización. 
      iniciarSyncListener({
        supabaseUrl: import.meta.env.PUBLIC_SUPABASE_URL ?? '',
        supabaseKey: import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '',
      }).catch((err) => {
        console.error('[BaseLayout] Error al iniciar el listener de sincronización:', err);
      });
    </script>
  </body>
</html>
