---
// ══════════════════════════════════════════════════════════════
// MUÑEGON POS — Layout Base
// Incluye: fuentes, CSS global, e inicialización del sync listener
// ══════════════════════════════════════════════════════════════

export interface Props {
  title?: string;
}

import '../styles/global.css';

const { title = 'Muñegon POS' } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Muñegon POS — Sistema de Punto de Venta e Inventario Offline-First" />
    <meta name="robots" content="noindex" /><!-- App de escritorio, no indexar -->

    <title>{title} | Muñegon POS</title>

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.png" />

    <!-- El CSS global se importa en el frontmatter para que Vite lo procese -->
  </head>

  <body>
    <slot />

    <!-- Inicializar el listener de sincronización al cargar la app -->
    <script>
      import { iniciarSyncListener } from '../lib/sync-listener';
      import { iniciarChequeoActualizaciones } from '../lib/auto-updater';

      // El listener escucha el evento de Rust. En la versión web (sin Tauri)
      // Rust nunca dispara el evento, por lo que este listener queda inactivo.
      // Las credenciales de Supabase llegan en el payload del evento (desde Rust),
      // nunca están expuestas como variables de entorno públicas.
      iniciarSyncListener().catch((err) => {
        console.error('[BaseLayout] Error al iniciar el listener de sincronización:', err);
      });

      // Iniciar chequeo de actualizaciones automáticamente al cargar la app
      iniciarChequeoActualizaciones();
    </script>
  </body>
</html>
