---
// Muñegon POS — Módulo de Reportes
// Acceso: solo ADMIN
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar';
import AuthGuard from '../components/AuthGuard';
import TablaCortes from '../components/reportes/TablaCortes';
import '../styles/sidebar.css';
import '../styles/admin.css';
---

<BaseLayout title="Reportes">
  <div class="app-layout">
    <Sidebar client:only="preact" />
    <div class="app-content">
      <AuthGuard rol="ADMIN" client:only="preact">
        <TablaCortes client:only="preact" />
      </AuthGuard>
    </div>
  </div>
</BaseLayout>
