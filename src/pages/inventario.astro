---
// Muñegon POS — Módulo de Inventario
// Acceso: solo ADMIN
import Sidebar from '../components/Sidebar';
import AuthGuard from '../components/AuthGuard';
import TablaInventario from '../components/inventario/TablaInventario';
import '../styles/sidebar.css';
import '../styles/admin.css';
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Inventario — Muñegon POS</title>
    <meta name="description" content="Gestión de inventario Muñegon POS" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="app-layout">
      <Sidebar client:only="preact" />
      <div class="app-content">
        <AuthGuard rol="ADMIN" client:only="preact">
          <TablaInventario client:only="preact" />
        </AuthGuard>
      </div>
    </div>
  </body>
</html>
